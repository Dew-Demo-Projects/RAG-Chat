<Window x:Class="chat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:chat"
        mc:Ignorable="d"
        Title="Ollama Genealogy Chat"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FF1F2430">

    <Window.Resources>
        <!-- Base colors -->
        <SolidColorBrush x:Key="PrimaryBackground" Color="#FF1F2430" />
        <SolidColorBrush x:Key="SecondaryBackground" Color="#FF2C3240" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF4E9AF1" />
        <SolidColorBrush x:Key="AccentBrushLight" Color="#FF69B4FF" />
        <SolidColorBrush x:Key="BorderBrushLight" Color="#334E9AF1" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFF5F5F5" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FFB0B3C0" />

        <!-- Used from code when creating FlowDocument -->
        <Style x:Key="DarkMarkdownStyle" TargetType="{x:Type FlowDocument}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="PagePadding" Value="0" />
        </Style>

        <!-- Hyperlinks (if any appear in FlowDocuments) -->
        <Style TargetType="{x:Type Hyperlink}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="TextDecorations" Value="{x:Null}" />
        </Style>

        <!-- Buttons -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrushLight}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBoxes -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}" />
            <Setter Property="BorderBrush" Value="#334E9AF1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Labels / TextBlocks -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}" />
            <Setter Property="BorderBrush" Value="#334E9AF1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PrimaryBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top header -->
        <Border Grid.Row="0" Background="#FF181C26" Padding="14,10"
                BorderBrush="#22000000" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Ollama Genealogy Chat"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Pytaj o osoby, rodziny i powiązania w Twojej bazie genealogicznej."
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main two‑column layout -->
        <Grid Grid.Row="1" Margin="14,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Chat panel -->
            <Border Grid.Column="0" Margin="0,0,8,0"
                    Background="{StaticResource SecondaryBackground}"
                    CornerRadius="6"
                    Padding="10"
                    BorderBrush="#22000000"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Chat -->
                    <ListBox Grid.Row="0"
                             Name="ChatList"
                             IsHitTestVisible="True"
                             ScrollViewer.CanContentScroll="False"
                             KeyboardNavigation.TabNavigation="None"
                             Background="{StaticResource SecondaryBackground}"
                             BorderThickness="0"
                             Padding="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             HorizontalContentAlignment="Stretch"
                             SelectionMode="Single">

                        <!-- Disable the “select/hover highlight box” behavior in the chat pane -->
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                                <!-- Important: keep a real root element so selection works -->
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Border Background="{TemplateBinding Background}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>



                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="8"
                                        Background="#221F2430"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Header}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="0,0,0,6" />

                                        <FlowDocumentScrollViewer Document="{Binding Document}"
                                                                  Background="Transparent"
                                                                  Foreground="{StaticResource TextBrush}"
                                                                  IsSelectionEnabled="True"
                                                                  IsToolBarVisible="False"
                                                                  Focusable="True"
                                                                  IsTabStop="False"
                                                                  VerticalScrollBarVisibility="Disabled"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  Margin="0"
                                                                  Padding="0" />

                                        <Button Content="Pokaż proces myślenia"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding ShowThinkingButton}"
                                                Tag="{Binding ThoughtId}"
                                                Click="ShowThinking_Click" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>


                    <!-- User input -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <TextBlock Text="Twoje pytanie"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,2" />
                        <TextBox Name="User"
                                 KeyDown="User_KeyDown"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 MinHeight="60" />
                    </StackPanel>

                    <!-- Send button row -->
                    <DockPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Text="Enter = wyślij, Shift+Enter = nowa linia"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <Button Content="Wyślij"
                                Width="90"
                                DockPanel.Dock="Right"
                                Click="SendButton_Click" />
                    </DockPanel>
                </Grid>
            </Border>

            <!-- Right side: context + plain-text details -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Znalezione informacje (Top 5)"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,4" />

                <ListBox Grid.Row="1"
                         Name="ContextList"
                         SelectionChanged="ContextList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="4"
                                    Background="#221F2430"
                                    CornerRadius="3">
                                <TextBlock Text="{Binding Content}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           MaxHeight="80" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Szczegóły wybranego elementu"
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="0,0,0,4" />

                    <TextBox Grid.Row="1"
                             Name="Details"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="2"
                Background="#FF181C26"
                BorderBrush="#22000000"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <DockPanel>
                <TextBlock Text="Połączony z lokalnym serwerem Ollama"
                           Foreground="{StaticResource MutedTextBrush}" />
                <TextBlock Name="RunStatusText"
                           Text=" • Gotowy"
                           Margin="4,0,0,0"
                           Foreground="{StaticResource AccentBrush}" />
            </DockPanel>
        </Border>

        <!-- Opaque thinking overlay (span all rows to silence Grid.Row warnings) -->
        <Grid Name="ThinkingOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Background="#CC000000"
              Panel.ZIndex="100">
            <Border Background="#FF2C3240"
                    BorderBrush="#334E9AF1"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Width="900"
                    Height="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Top"
                            Content="Zamknij"
                            Width="90"
                            Click="CloseThinking_Click" />
                    <TextBox Name="ThinkingText"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Background="#FF1F2430"
                             Foreground="#FFF5F5F5" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>